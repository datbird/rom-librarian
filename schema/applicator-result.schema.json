{
  "$schema": "https://json-schema.org/draft/07/schema",
  "$id": "https://github.com/datbird/rom-librarian/schema/applicator-result.schema.json",
  "title": "rom-librarian applicator result",
  "type": "object",
  "required": ["operation", "mode", "status", "target", "real_target", "changes", "verification", "backup_manifest", "notes"],
  "properties": {
    "operation": {
      "type": "string",
      "enum": ["apply-m3u-case-fixes", "apply-cue-case-fixes", "apply-gdi-case-fixes", "apply-missing-m3u-playlists", "apply-empty-folder-cleanup", "apply-orphaned-media-quarantine"]
    },
    "mode": { "type": "string", "enum": ["mutating"] },
    "status": { "type": "string", "enum": ["applied"] },
    "target": { "type": "string" },
    "real_target": { "type": "boolean" },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["operation", "applied"],
        "properties": {
          "operation": { "type": "string" },
          "applied": { "type": "boolean", "enum": [true] }
        },
        "additionalProperties": true
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["verified", "check"],
        "properties": {
          "verified": { "type": "boolean", "enum": [true] },
          "check": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "backup_manifest": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
