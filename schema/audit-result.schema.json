{
  "$schema": "https://json-schema.org/draft/07/schema",
  "$id": "https://github.com/datbird/rom-librarian/schema/audit-result.schema.json",
  "title": "rom-librarian audit result",
  "type": "object",
  "required": ["audit", "mode", "status", "findings"],
  "properties": {
    "audit": { "type": "string" },
    "target": { "type": ["string", "null"] },
    "mode": { "type": "string", "enum": ["read-only"] },
    "status": { "type": "string" },
    "checks": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "object" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "severity": { "type": "string", "enum": ["info", "warning", "error"] },
          "type": { "type": "string" },
          "likely_cause": { "type": "string" },
          "suggested_dry_run_repair": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
