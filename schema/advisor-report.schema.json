{
  "$schema": "https://json-schema.org/draft/07/schema",
  "$id": "https://github.com/datbird/rom-librarian/schema/advisor-report.schema.json",
  "title": "rom-librarian advisor report",
  "type": "object",
  "required": ["report", "mode", "status", "inputs", "records", "recommended_commands", "forbidden_actions", "notes"],
  "properties": {
    "report": { "type": "string", "enum": ["advisor"] },
    "mode": { "type": "string", "enum": ["read-only"] },
    "status": { "type": "string", "enum": ["completed"] },
    "inputs": { "type": "object" },
    "records": { "type": "object" },
    "recommended_commands": { "type": "array", "items": { "type": "object" } },
    "forbidden_actions": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
