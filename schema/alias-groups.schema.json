{
  "$schema": "https://json-schema.org/draft/07/schema",
  "$id": "https://github.com/datbird/rom-librarian/schema/alias-groups.schema.json",
  "title": "rom-librarian expected system alias groups",
  "type": "object",
  "required": ["version", "sources", "groups"],
  "properties": {
    "version": { "type": "string" },
    "sources": { "type": "array", "items": { "$ref": "source.schema.json" } },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["canonical", "aliases", "reason"],
        "properties": {
          "canonical": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "reason": { "type": "string" },
          "status": { "type": "string", "enum": ["canonical_alias", "split_records", "static_deferred"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
