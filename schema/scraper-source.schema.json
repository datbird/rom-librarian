{
  "$schema": "https://json-schema.org/draft/07/schema",
  "$id": "https://github.com/datbird/rom-librarian/schema/scraper-source.schema.json",
  "title": "rom-librarian scraper source record",
  "type": "object",
  "required": ["id", "name", "category", "homepage", "sources", "access", "provides", "notes"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "category": { "type": "string", "enum": ["metadata_source", "media_source", "database", "archive", "hybrid"] },
    "homepage": { "type": ["string", "null"] },
    "sources": { "type": "array", "items": { "$ref": "source.schema.json" } },
    "access": { "type": "object" },
    "provides": { "type": "object" },
    "coverage": { "type": "object" },
    "rate_limits": { "type": "object" },
    "legal_notes": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
