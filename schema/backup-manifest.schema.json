{
  "$schema": "https://json-schema.org/draft/07/schema",
  "$id": "https://github.com/datbird/rom-librarian/schema/backup-manifest.schema.json",
  "title": "rom-librarian backup manifest",
  "type": "object",
  "required": ["operation_id", "created_at", "audit", "target", "real_target", "planned_changes", "backup_paths", "rollback_notes"],
  "properties": {
    "operation_id": { "type": "string" },
    "created_at": { "type": "string" },
    "audit": { "type": "string", "enum": ["m3u", "cue", "gdi", "empty-folders", "media-paths"] },
    "target": { "type": "string" },
    "real_target": { "type": "boolean" },
    "files_before": { "type": "array", "items": { "type": "string" } },
    "planned_changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["operation", "applied"],
        "properties": {
          "operation": { "type": "string" },
          "applied": { "type": "boolean", "enum": [true] }
        },
        "additionalProperties": true
      }
    },
    "backup_paths": { "type": "array", "items": { "type": "string" } },
    "rollback_notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
