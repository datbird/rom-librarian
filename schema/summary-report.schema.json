{
  "$schema": "https://json-schema.org/draft/07/schema",
  "$id": "https://github.com/datbird/rom-librarian/schema/summary-report.schema.json",
  "title": "rom-librarian summary report",
  "type": "object",
  "required": ["report", "mode", "status", "normalized_counts", "coverage", "recommended_next", "fixture_audits", "mutating_applicators", "notes"],
  "properties": {
    "report": { "type": "string", "enum": ["summary"] },
    "mode": { "type": "string", "enum": ["read-only"] },
    "status": { "type": "string", "enum": ["completed"] },
    "normalized_counts": {
      "type": "object",
      "required": ["frontends", "systems", "emulators", "scraper_sources", "scraper_tools", "metadata_stores"],
      "properties": {
        "frontends": { "type": "integer", "minimum": 0 },
        "systems": { "type": "integer", "minimum": 0 },
        "emulators": { "type": "integer", "minimum": 0 },
        "scraper_sources": { "type": "integer", "minimum": 0 },
        "scraper_tools": { "type": "integer", "minimum": 0 },
        "metadata_stores": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": ["systems_percent", "emulators_percent", "systems_missing", "emulators_missing"],
      "properties": {
        "systems_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "emulators_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "systems_missing": { "type": "integer", "minimum": 0 },
        "emulators_missing": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "recommended_next": {
      "type": "object",
      "required": ["systems", "emulators"],
      "properties": {
        "systems": { "$ref": "#/definitions/recommendations" },
        "emulators": { "$ref": "#/definitions/recommendations" }
      },
      "additionalProperties": false
    },
    "fixture_audits": { "type": "integer", "minimum": 0 },
    "mutating_applicators": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "definitions": {
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "bucket", "priority_reason"],
        "properties": {
          "id": { "type": "string" },
          "bucket": { "type": "string" },
          "priority_reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
