{
  "$schema": "https://json-schema.org/draft/07/schema",
  "$id": "https://github.com/datbird/rom-librarian/schema/asset-taxonomy.schema.json",
  "title": "rom-librarian asset taxonomy",
  "type": "object",
  "required": ["version", "sources", "asset_types", "metadata_fields"],
  "properties": {
    "version": { "type": "string" },
    "sources": { "type": "array", "items": { "$ref": "source.schema.json" } },
    "asset_types": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["label", "category", "aliases", "file_types", "description"],
        "properties": {
          "label": { "type": "string" },
          "category": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "file_types": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" },
          "frontend_mappings": { "type": "object" }
        }
      }
    },
    "metadata_fields": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["label", "category", "aliases", "description"],
        "properties": {
          "label": { "type": "string" },
          "category": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" },
          "frontend_mappings": { "type": "object" }
        }
      }
    }
  }
}
