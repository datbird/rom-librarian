{
  "$schema": "https://json-schema.org/draft/07/schema",
  "$id": "https://github.com/datbird/rom-librarian/schema/rollback-result.schema.json",
  "title": "rom-librarian rollback result",
  "type": "object",
  "required": ["operation", "mode", "status", "target", "real_target", "manifest", "restored", "notes"],
  "properties": {
    "operation": { "type": "string", "enum": ["rollback-backup-manifest"] },
    "mode": { "type": "string", "enum": ["mutating", "dry-run"] },
    "status": { "type": "string", "enum": ["restored", "planned"] },
    "target": { "type": "string" },
    "real_target": { "type": "boolean" },
    "manifest": { "type": "string" },
    "restored": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["operation", "destination", "restored", "applied"],
        "properties": {
          "operation": { "type": "string", "enum": ["restore_backup_file", "delete_generated_file", "restore_empty_folder", "restore_quarantined_file"] },
          "destination": { "type": "string" },
          "backup_path": { "type": "string" },
          "restored": { "type": "boolean" },
          "applied": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
