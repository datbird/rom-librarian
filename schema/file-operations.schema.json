{
  "$schema": "https://json-schema.org/draft/07/schema",
  "$id": "https://github.com/datbird/rom-librarian/schema/file-operations.schema.json",
  "title": "rom-librarian constrained file operations plan",
  "type": "object",
  "required": ["plan_type", "operation_id", "audit", "target", "operations", "rollback_notes"],
  "properties": {
    "plan_type": { "type": "string", "enum": ["file_operations"] },
    "operation_id": { "type": "string" },
    "audit": { "type": "string", "enum": ["empty-folders", "media-paths"] },
    "target": { "type": "string" },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["op", "path"],
        "properties": {
          "op": { "type": "string", "enum": ["delete_empty_dir", "move_to_quarantine"] },
          "path": { "type": "string" },
          "quarantine_path": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "rollback_notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
