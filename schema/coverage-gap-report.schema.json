{
  "$schema": "https://json-schema.org/draft/07/schema",
  "$id": "https://github.com/datbird/rom-librarian/schema/coverage-gap-report.schema.json",
  "title": "rom-librarian coverage gap report",
  "type": "object",
  "required": ["report", "mode", "status", "filters", "systems", "emulators", "notes"],
  "properties": {
    "report": { "type": "string", "enum": ["coverage-gaps"] },
    "mode": { "type": "string", "enum": ["read-only"] },
    "status": { "type": "string", "enum": ["completed"] },
    "filters": {
      "type": "object",
      "required": ["section", "limit"],
      "properties": {
        "section": { "type": ["string", "null"], "enum": ["systems", "emulators", null] },
        "limit": { "type": ["integer", "null"], "minimum": 1 }
      },
      "additionalProperties": false
    },
    "systems": { "$ref": "#/definitions/coverageSection" },
    "emulators": { "$ref": "#/definitions/coverageSection" },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "definitions": {
    "coverageSection": {
      "type": "object",
      "required": ["active", "static_count", "normalized_count", "covered_count", "alias_covered_count", "missing_count", "normalized_percent", "buckets", "recommended_next", "alias_covered", "missing"],
      "properties": {
        "active": { "type": "boolean" },
        "static_count": { "type": "integer", "minimum": 0 },
        "normalized_count": { "type": "integer", "minimum": 0 },
        "covered_count": { "type": "integer", "minimum": 0 },
        "alias_covered_count": { "type": "integer", "minimum": 0 },
        "missing_count": { "type": "integer", "minimum": 0 },
        "normalized_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "buckets": {
          "type": "object",
          "properties": {
            "engine_or_source_port": { "type": "integer", "minimum": 0 },
            "launcher_or_runtime": { "type": "integer", "minimum": 0 },
            "arcade_or_dat_sensitive": { "type": "integer", "minimum": 0 },
            "disc_or_multidisc": { "type": "integer", "minimum": 0 },
            "bios_or_firmware_sensitive": { "type": "integer", "minimum": 0 },
            "launcher_or_installed_app": { "type": "integer", "minimum": 0 },
            "standard_media": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "recommended_next": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "bucket", "priority_reason"],
            "properties": {
              "id": { "type": "string" },
              "bucket": { "$ref": "#/definitions/bucket" },
              "priority_reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "alias_covered": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "missing": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "bucket": {
      "type": "string",
      "enum": ["engine_or_source_port", "launcher_or_runtime", "arcade_or_dat_sensitive", "disc_or_multidisc", "bios_or_firmware_sensitive", "launcher_or_installed_app", "standard_media"]
    }
  },
  "additionalProperties": false
}
