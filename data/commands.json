{
  "version": "1.0.0",
  "commands": [
    { "id": "audit:m3u", "command": "npm run audit:m3u -- <path>", "category": "audit", "mutates": false, "inputs": ["library path"], "outputs": ["audit JSON"], "safety_gates": [] },
    { "id": "audit:cue", "command": "npm run audit:cue -- <path>", "category": "audit", "mutates": false, "inputs": ["library path"], "outputs": ["audit JSON"], "safety_gates": [] },
